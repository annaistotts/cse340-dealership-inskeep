<% if (!vehicle) { %>
	<section class="section-heading section-heading--stacked empty-state">
		<div>
			<p class="eyebrow">Not found</p>
			<h1>We could not find that page.</h1>
		</div>
		<p>The vehicle or page you requested is no longer available. Explore the current inventory instead.</p>
		<a class="button button--primary" href="/vehicles">Back to inventory</a>
	</section>
<% } else { %>
	<section class="detail-hero">
		<div class="detail-hero__content">
			<span class="availability-badge availability-badge--<%= vehicle.availability ? vehicle.availability.toLowerCase() : 'unknown' %>">
				<%= vehicle.availability ? vehicle.availability.charAt(0).toUpperCase() + vehicle.availability.slice(1).toLowerCase() : 'Unknown' %>
			</span>
			<h1><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h1>
			<p><%= vehicle.description %></p>

			<dl class="detail-specs">
				<div>
					<dt>Price</dt>
					<dd>$<%= Number(vehicle.price).toLocaleString() %></dd>
				</div>
				<div>
					<dt>Mileage</dt>
					<dd><%= Number(vehicle.mileage).toLocaleString() %> miles</dd>
				</div>
				<div>
					<dt>Fuel</dt>
					<dd><%= vehicle.fuel_type %></dd>
				</div>
				<div>
					<dt>Transmission</dt>
					<dd><%= vehicle.transmission %></dd>
				</div>
			</dl>

			<div class="hero__actions">
				<a class="button button--secondary" href="/vehicles">Back to inventory</a>
			</div>
		</div>

		<div class="detail-hero__media">
			<% if (vehicle.image_path) { %>
				<img src="<%= vehicle.image_path %>" alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>">
			<% } else { %>
				<span>Vehicle image coming soon</span>
			<% } %>
		</div>
	</section>

	<section class="detail-grid">
		<article class="detail-card">
			<h2>Vehicle overview</h2>
			<p><%= vehicle.description %></p>
		</article>

		<article class="detail-card">
			<h2>Quick highlights</h2>
			<ul class="feature-list">
				<li><strong>Transmission:</strong> <%= vehicle.transmission %></li>
				<li><strong>Fuel Type:</strong> <%= vehicle.fuel_type %></li>
				<li><strong>Mileage:</strong> <%= Number(vehicle.mileage).toLocaleString() %> miles</li>
				<li><strong>Status:</strong> <span class="availability-badge availability-badge--<%= vehicle.availability ? vehicle.availability.toLowerCase() : 'unknown' %>">
					<%= vehicle.availability ? vehicle.availability.charAt(0).toUpperCase() + vehicle.availability.slice(1).toLowerCase() : 'Unknown' %>
				</span></li>
			</ul>
		</article>
	</section>

	<section class="vehicle-reviews">
		<h2>Customer Reviews</h2>

		<% if (reviews && reviews.length > 0) { %>
			<div class="review-list">
				<% reviews.forEach(review => { %>
					<article class="review-card">
						<h3><%= review.first_name %> <%= review.last_name %></h3>
						<p>Rating: <%= review.rating %>/5</p>
						<p><%= review.review_text %></p>

						<% if (currentUser && currentUser.user_id === review.user_id) { %>
							<div class="review-actions">
								<a class="review-action-button" href="/vehicles/<%= vehicle.slug %>/reviews/<%= review.review_id %>/edit">Edit</a>

								<form action="/vehicles/<%= vehicle.slug %>/reviews/<%= review.review_id %>/delete" method="post">
									<button class="review-action-button" type="submit">Delete</button>
								</form>
							</div>
						<% } %>
					</article>
				<% }) %>
			</div>
		<% } else { %>
			<p>No reviews yet.</p>
		<% } %>

		<% if (currentUser) { %>
			<form action="/vehicles/<%= vehicle.slug %>/reviews" method="post" class="review-form">
				<input type="hidden" name="vehicle_id" value="<%= vehicle.vehicle_id %>">

				<div>
					<label for="rating">Rating</label>
					<select name="rating" id="rating" required>
						<option value="">Select rating</option>
						<option value="5">5</option>
						<option value="4">4</option>
						<option value="3">3</option>
						<option value="2">2</option>
						<option value="1">1</option>
					</select>
				</div>

				<div>
					<label for="review_text">Your Review</label>
					<textarea name="review_text" id="review_text" rows="5" required></textarea>
				</div>

				<button type="submit">Leave Review</button>
			</form>
		<% } else { %>
			<p><a href="/login">Sign in</a> to leave a review.</p>
		<% } %>
	</section>
<% } %>