<div class="site-header-wrap">
  <header class="site-header">
    <a class="brand" href="/">
      <span class="brand__name"><%= siteName %></span>
      <span class="brand__tag">Quality used vehicles for everyday drivers</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a class="<%= currentPath === '/' ? 'is-active' : '' %>" href="/">Home</a>
      <% if (!currentUser || currentUser.role === 'customer') { %>
        <a class="<%= currentPath === '/contact' ? 'is-active' : '' %>" href="/contact">Contact</a>
      <% } %>
      <% if (currentUser && (currentUser.role === 'employee' || currentUser.role === 'owner')) { %>
        <a class="<%= currentPath.startsWith('/admin/dashboard') || currentPath.startsWith('/owner') ? 'is-active' : '' %>" href="<%= currentUser.role === 'owner' ? '/owner' : '/admin/dashboard' %>">Dashboard</a>
        <a href="/logout">Logout</a>
      <% } else { %>
        <a class="<%= currentPath.startsWith('/vehicles') ? 'is-active' : '' %>" href="/vehicles">Inventory</a>
        <% if (currentUser) { %>
          <a class="<%= currentPath === '/service' ? 'is-active' : '' %>" href="/service">Service</a>
          <a class="<%= currentPath.startsWith('/service/history') ? 'is-active' : '' %>" href="/service/history">My Service Requests</a>
          <a href="/logout">Logout</a>
        <% } else { %>
          <a class="<%= currentPath === '/login' ? 'is-active' : '' %>" href="/login">Sign in</a>
        <% } %>
      <% } %>
    </nav>
  </header>
</div>