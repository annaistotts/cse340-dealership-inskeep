<section class="section-heading section-heading--stacked">
	<div>
		<p class="eyebrow">500</p>
		<h1>Something Went Wrong</h1>
	</div>
	<p>We are experiencing technical difficulties. Our team has been notified and is working to fix the issue.</p>
	<p><a class="text-link" href="/">Return to homepage</a></p>
</section>

<% if (NODE_ENV === 'development') { %>
	<section class="form-shell">
		<details open>
			<summary>Error Details (Development Only)</summary>
			<pre class="error-stack"><%= error %></pre>
			<pre class="error-stack"><%= stack %></pre>
		</details>
	</section>
<% } %>
