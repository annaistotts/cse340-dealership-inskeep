<section class="section-heading">
  <h1>Service Request Details</h1>
</section>

<article class="review-card">
  <h2><%= request.vehicle_year %> <%= request.vehicle_make %> <%= request.vehicle_model %></h2>
  <p><strong>Customer:</strong> <%= request.first_name %> <%= request.last_name %></p>
  <p><strong>Email:</strong> <%= request.email %></p>
  <p><strong>Service Type:</strong> <%= request.service_type %></p>
  <p><strong>Description:</strong> <%= request.request_description || 'No description provided.' %></p>
  <p><strong>Current Status:</strong> <%= request.status %></p>

  <form action="/admin/service/<%= request.request_id %>" method="post" class="auth-form">
    <div>
      <label for="status">Update Status</label>
      <select id="status" name="status" required>
        <option value="Submitted" <%= request.status === 'Submitted' ? 'selected' : '' %>>Submitted</option>
        <option value="In Progress" <%= request.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
        <option value="Completed" <%= request.status === 'Completed' ? 'selected' : '' %>>Completed</option>
      </select>
    </div>

    <div>
      <label for="employee_notes">Employee Notes</label>
      <textarea id="employee_notes" name="employee_notes" rows="5"><%= request.employee_notes || '' %></textarea>
    </div>

    <button type="submit">Save Changes</button>
  </form>
</article>