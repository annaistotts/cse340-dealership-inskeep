<section class="section-heading admin-service-heading">
  <h1>Manage Vehicles</h1>
  <% if (currentUser && currentUser.role === 'owner') { %>
    <a class="button button--primary" href="/owner/vehicles/add">Add Vehicle</a>
  <% } %>
</section>

<% if (!vehicles.length) { %>
  <p>No vehicles found.</p>
<% } else { %>
  <div class="review-list">
    <% vehicles.forEach((vehicle) => { %>
      <article class="review-card">
        <h3><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h3>

        <p>
          <strong>Price:</strong>
          $<%= Number(vehicle.price).toLocaleString() %>
        </p>

        <p>
          <strong>Availability:</strong>
          <%= vehicle.availability
            ? vehicle.availability.charAt(0).toUpperCase() + vehicle.availability.slice(1).toLowerCase()
            : '' %>
        </p>

        <p><strong>Description:</strong> <%= vehicle.description %></p>

        <div class="hero__actions">
          <a
            class="review-action-button"
            href="<%= currentUser && currentUser.role === 'owner' ? `/owner/vehicles/${vehicle.vehicle_id}/edit` : `/admin/vehicles/${vehicle.vehicle_id}/edit` %>"
          >
            Edit
          </a>

          <% if (currentUser && currentUser.role === 'owner') { %>
            <form
              action="/owner/vehicles/<%= vehicle.vehicle_id %>/delete"
              method="post"
            >
              <button type="submit">Delete</button>
            </form>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>