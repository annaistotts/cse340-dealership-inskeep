<section class="section-heading section-heading--stacked">
  <div>
    <p class="eyebrow"><%= isOwner ? 'Owner' : 'Employee' %></p>
    <h1><%= isOwner ? 'Owner Dashboard' : 'Dashboard' %></h1>
  </div>
  <p>Quick access to <%= isOwner ? 'owner and employee' : 'employee' %> tools.</p>
</section>

<% if (counts) { %>
<section class="detail-grid owner-totals-grid">
  <article class="detail-card">
    <h2>Total Users</h2>
    <p><%= counts.user_count %></p>
  </article>

  <article class="detail-card">
    <h2>Total Vehicles</h2>
    <p><%= counts.vehicle_count %></p>
  </article>

  <article class="detail-card">
    <h2>Total Reviews</h2>
    <p><%= counts.review_count %></p>
  </article>

  <article class="detail-card">
    <h2>Service Requests</h2>
    <p><%= counts.service_request_count %></p>
  </article>

  <article class="detail-card">
    <h2>Contact Messages</h2>
    <p><%= counts.contact_message_count %></p>
  </article>
</section>
<% } %>

<section class="detail-grid">
  <article class="detail-card">
    <h2>Manage Vehicles</h2>
    <p>Edit vehicle price, description, and availability.</p>
    <a class="button button--primary" href="/owner/vehicles">Open Vehicle Manager</a>
  </article>

  <article class="detail-card">
    <h2>Moderate Reviews</h2>
    <p>Review customer feedback and remove inappropriate posts.</p>
    <a class="button button--primary" href="/admin/reviews">Open Review Moderation</a>
  </article>

  <article class="detail-card">
    <h2>Service Requests</h2>
    <p>Review and update customer service requests.</p>
    <a class="button button--primary" href="/admin/service">Open Service Requests</a>
  </article>

  <article class="detail-card">
    <h2>Vehicle Inventory</h2>
    <p>Browse current inventory details.</p>
    <a class="button button--primary" href="/vehicles">Open Inventory</a>
  </article>

  <% if (isOwner) { %>
    <article class="detail-card">
      <h2>Owner Categories</h2>
      <p>Create, edit, and remove inventory categories.</p>
      <a class="button button--primary" href="/owner/categories">Open Categories</a>
    </article>

    <article class="detail-card">
      <h2>Contact Submissions</h2>
      <p>View customer messages and respond directly by email.</p>
      <a class="button button--primary" href="/owner/contact">Open Contact Inbox</a>
    </article>
  <% } %>
</section>

<% if (isOwner && users) { %>
<section class="section-heading">
  <h2>User Accounts</h2>
</section>

<% if (!users.length) { %>
  <p>No users found.</p>
<% } else { %>
  <div class="review-list">
    <% users.forEach((user) => { %>
      <article class="review-card">
        <h3><%= user.first_name %> <%= user.last_name %></h3>
        <p><strong>Email:</strong> <%= user.email %></p>
        <p><strong>Role:</strong> <%= user.role %></p>
        <p><strong>Joined:</strong> <%= new Date(user.created_at).toLocaleDateString() %></p>
        <% if (user.role !== 'owner') { %>
          <form class="review-actions" action="/owner/users/<%= user.user_id %>/role" method="post">
            <select name="role" aria-label="Update role for <%= user.email %>">
              <option value="customer" <%= user.role === 'customer' ? 'selected' : '' %>>Customer</option>
              <option value="employee" <%= user.role === 'employee' ? 'selected' : '' %>>Employee</option>
            </select>
            <button class="review-action-button" type="submit">Update Role</button>
          </form>
        <% } %>
      </article>
    <% }) %>
  </div>
<% } %>
<% } %>
