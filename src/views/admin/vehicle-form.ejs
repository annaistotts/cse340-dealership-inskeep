<section class="auth-page">
  <h1><%= vehicle ? 'Edit Vehicle' : 'Add Vehicle' %></h1>

  <form
    action="<%= vehicle ? `/owner/vehicles/${vehicle.vehicle_id}/edit` : '/owner/vehicles/add' %>"
    method="post"
    class="auth-form"
  >
    <div>
      <label for="category_id">Category</label>
      <select id="category_id" name="category_id" required>
        <% categories.forEach(category => { %>
          <option
            value="<%= category.category_id %>"
            <%= vehicle && vehicle.category_id === category.category_id ? 'selected' : '' %>
          >
            <%= category.category_name %>
          </option>
        <% }) %>
      </select>
    </div>

    <div>
      <label for="year">Year</label>
      <input type="number" id="year" name="year" value="<%= vehicle ? vehicle.year : '' %>" required>
    </div>

    <div>
      <label for="make">Make</label>
      <input type="text" id="make" name="make" value="<%= vehicle ? vehicle.make : '' %>" required>
    </div>

    <div>
      <label for="model">Model</label>
      <input type="text" id="model" name="model" value="<%= vehicle ? vehicle.model : '' %>" required>
    </div>

    <div>
      <label for="price">Price</label>
      <input type="number" step="0.01" id="price" name="price" value="<%= vehicle ? vehicle.price : '' %>" required>
    </div>

    <div>
      <label for="mileage">Mileage</label>
      <input type="number" id="mileage" name="mileage" value="<%= vehicle ? vehicle.mileage : '' %>">
    </div>

    <div>
      <label for="transmission">Transmission</label>
      <input type="text" id="transmission" name="transmission" value="<%= vehicle ? vehicle.transmission : '' %>">
    </div>

    <div>
      <label for="fuel_type">Fuel Type</label>
      <input type="text" id="fuel_type" name="fuel_type" value="<%= vehicle ? vehicle.fuel_type : '' %>">
    </div>

    <div>
      <label for="availability">Availability</label>
      <input type="text" id="availability" name="availability" value="<%= vehicle ? vehicle.availability : 'available' %>" required>
    </div>

    <div>
      <label for="featured">Featured</label>
      <select id="featured" name="featured">
        <option value="false" <%= vehicle && !vehicle.featured ? 'selected' : '' %>>No</option>
        <option value="true" <%= vehicle && vehicle.featured ? 'selected' : '' %>>Yes</option>
      </select>
    </div>

    <div>
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="5" required><%= vehicle ? vehicle.description : '' %></textarea>
    </div>

    <button type="submit"><%= vehicle ? 'Save Changes' : 'Add Vehicle' %></button>
  </form>
</section>